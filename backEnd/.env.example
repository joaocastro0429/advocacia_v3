jJWT_SECRET="your-super-secret-key"
JWT_RESET_SECRET="your-reset-secret-key"

# Database (docker-compose default)
# Senha "advocacia@ad" precisa ser URL-encoded como "%40" em connection strings.
DATABASE_URL=postgresql://advocacia:advocacia%40ad@localhost:5432/advocacia?schema=public

# Port
PORT=3333

# CORS
CORS_ORIGIN=http://localhost:5173

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# Mail provider: smtp | resend
MAIL_PROVIDER=smtp

# SMTP (password reset e-mail)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_password
# Gmail: use senha de app (16 chars) em vez da senha normal da conta.
# EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=LexOffice <no-reply@example.com>
SMTP_TEST_TO=user@example.com

# Dev-only: retorna o link de reset na resposta e ignora SMTP
# (somente fora de production)
PASSWORD_RESET_DEBUG_RESPONSE=false

# Resend (recommended for production)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_API_URL=https://api.resend.com/emails
